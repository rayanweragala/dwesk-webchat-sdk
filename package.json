{
  "name": "dwesk-webchat-sdk",
  "version": "2.0.0",
  "description": "Bun-first TypeScript SDK for Dwesk web chat integrations",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./webhook": {
      "types": "./src/webhook.ts",
      "import": "./src/webhook.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts ./src/webhook.ts --outdir ./dist --target browser",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "dwesk",
    "webchat",
    "bun",
    "typescript",
    "sdk"
  ],
  "author": "Rayan Weragala <rayanthilakshana2000@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "ngrok": "^5.0.0-beta.2"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  }
}
